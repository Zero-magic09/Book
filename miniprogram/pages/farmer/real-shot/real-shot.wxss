/* pages/farmer/real-shot/real-shot.wxss */
.container {
  min-height: 100vh;
  background-color: #f8fafc;
  padding: 32rpx 32rpx 180rpx;
}

.shot-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.shot-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #94a3b8;
}

.sort-btn {
  font-size: 24rpx;
  color: #10b981; /* Green color */
  font-weight: 500;
}

.shot-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 48rpx;
}

.shot-item {
  width: calc((100% - 20rpx) / 2); /* Two items per row with gap */
  height: 330rpx; /* Approximate square-ish */
  position: relative;
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.shot-img {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  background-color: #f1f5f9;
}

.close-btn {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 44rpx;
  height: 44rpx;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  line-height: 1;
}

.add-shot-btn {
  width: calc((100% - 20rpx) / 2);
  height: 330rpx;
  border-radius: 24rpx;
  border: 4rpx dashed #d1fae5; /* Light green dashed */
  box-sizing: border-box; /* Include border */
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #10b981;
  background-color: #fff;
}

.add-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  background-color: #ecfdf5;
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 300;
}

.add-text {
  font-size: 26rpx;
  font-weight: 500;
}

/* Requirements Section */
.requirements-section {
  background-color: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(148, 163, 184, 0.02);
}

.req-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 24rpx;
}

.req-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.req-item {
  font-size: 26rpx;
  color: #94a3b8; /* Gray text */
  line-height: 1.5;
}

.save-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx 40rpx calc(30rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -10rpx 30rpx rgba(0,0,0,0.05);
  z-index: 100;
}

.save-btn {
  height: 90rpx;
  background: #f3f4f6;
  color: #9ca3af;
  border-radius: 45rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
  transition: all 0.3s;
}

.save-btn.active {
  background: #10b981;
  color: #fff;
  box-shadow: 0 10rpx 20rpx rgba(16, 185, 129, 0.2);
}

.shot-grid {
  position: relative;
}

.shot-item.hidden {
  opacity: 0;
}

.drag-mirror {
  position: absolute;
  z-index: 999;
  pointer-events: none;
  transform: translate(-50%, -50%);
  border-radius: 24rpx;
  box-shadow: 0 20rpx 40rpx rgba(0,0,0,0.2);
  transition: transform 0.1s linear;
}
