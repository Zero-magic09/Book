<view class="container">
  
  <!-- 1. Balance Card -->
  <view class="balance-card">
    <view class="balance-bg">
       <view class="balance-label">账户余额</view>
       <view class="balance-val">
         <text class="symbol">¥</text> {{balance}}
       </view>
       <view class="withdraw-btn" bindtap="handleWithdraw">申请提现</view>
       <!-- Decoration Icon -->
       <view class="bg-icon">$</view>
    </view>
  </view>

  <!-- 2. Bind Methods -->
  <view class="section-header">
    <view class="section-title">绑定方式</view>
    <view class="add-action" bindtap="handleAddAccount">+ 添加账户</view>
  </view>

  <view class="account-list">
    <block wx:for="{{accounts}}" wx:key="id">
      <view class="account-card">
        <view class="account-icon-box bank">
          <text class="icon">🏦</text>
        </view>
        <view class="account-info">
          <view class="account-name">{{item.bankName}}</view>
          <view class="account-desc">{{item.accountNumber}} ({{item.accountHolder}})</view>
        </view>
        <view class="status-btn delete" bindtap="handleDelete" data-id="{{item.id}}">
          删除
        </view>
      </view>
    </block>
    <view wx:if="{{accounts.length === 0}}" class="empty-tip">暂无绑定账户</view>
  </view>

  <!-- 3. Info Box -->
  <view class="info-box">
    <view class="info-icon">💡</view>
    <view class="info-content">
      <view class="info-title">结算说明</view>
      <view class="info-text">
        平台每笔交易手续费为0.5%，资金在买家确认收货后即刻进入余额。如需修改结算账户，需通过管理员人工核实。
      </view>
    </view>
  </view>

  <!-- 4. Withdrawal Modal -->
  <view class="modal-overlay {{showWithdrawModal ? 'show' : ''}}" bindtap="closeWithdrawModal">
    <view class="modal-content" catchtap="preventStop">
      <view class="modal-header">
        <text class="modal-title">申请提现</text>
        <view class="close-icon" bindtap="closeWithdrawModal">×</view>
      </view>
      
      <view class="modal-body">
        <view class="withdraw-amount-section">
          <view class="input-label">提现金额</view>
          <view class="amount-input-box">
            <text class="currency">¥</text>
            <input 
              class="amount-input" 
              type="digit" 
              placeholder="0.00" 
              placeholder-class="ph-style" 
              focus="{{showWithdrawModal}}"
              value="{{withdrawAmount}}"
              bindinput="onWithdrawInput"
            />
          </view>
          <view class="balance-info">
            <text>可用余额 ¥{{balance}}</text>
            <text class="all-btn" bindtap="handleWithdrawAll">全部提现</text>
          </view>
        </view>

        <view class="account-select-section" wx:if="{{accounts.length > 0}}">
          <view class="input-label">提现至</view>
          <picker bindchange="onAccountChange" value="{{selectedAccountIndex}}" range="{{accounts}}" range-key="bankName">
            <view class="selected-account">
              <text>🏦 {{accounts[selectedAccountIndex].bankName}} ({{accounts[selectedAccountIndex].accountNumber}})</text>
              <text class="arrow">推荐 > </text>
            </view>
          </picker>
        </view>
      </view>

      <view class="modal-footer">
        <view class="confirm-btn {{withdrawAmount > 0 ? 'active' : ''}}" bindtap="submitWithdraw">确认提现</view>
      </view>
    </view>
  </view>

  <!-- 5. Add Account Modal -->
  <view class="modal-overlay {{showAddAccountModal ? 'show' : ''}}" bindtap="closeAddAccountModal">
    <view class="modal-content" catchtap="preventStop">
      <view class="modal-header">
        <text class="modal-title">添加结算账户</text>
        <view class="close-icon" bindtap="closeAddAccountModal">×</view>
      </view>
      
      <view class="modal-body">
        <view class="form-item">
          <view class="input-label">银行名称</view>
          <input 
            class="form-input" 
            placeholder="例如：中国工商银行" 
            value="{{newAccount.bankName}}"
            data-field="bankName"
            bindinput="onAccountInput"
          />
        </view>

        <view class="form-item">
          <view class="input-label">银行卡号</view>
          <input 
            class="form-input" 
            type="number"
            placeholder="请输入持卡人本人的银行卡号" 
            value="{{newAccount.accountNumber}}"
            data-field="accountNumber"
            bindinput="onAccountInput"
          />
        </view>

        <view class="form-item">
          <view class="input-label">持卡人姓名</view>
          <input 
            class="form-input" 
            placeholder="必须与实名认证姓名一致" 
            value="{{newAccount.accountHolder}}"
            data-field="accountHolder"
            bindinput="onAccountInput"
          />
        </view>
      </view>

      <view class="modal-footer">
        <view 
          class="confirm-btn {{newAccount.bankName && newAccount.accountNumber && newAccount.accountHolder ? 'active' : ''}}" 
          bindtap="submitAddAccount"
        >保存账户</view>
      </view>
    </view>
  </view>

</view>
