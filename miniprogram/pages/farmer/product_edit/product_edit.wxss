/* pages/farmer/product_edit/product_edit.wxss */
.container {
  min-height: 100vh;
  background-color: #f7f9fc;
  padding: 32rpx;
  padding-bottom: 200rpx;
}

.section-card {
  background-color: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #94a3b8; /* Slate-400 equivalent */
  margin-bottom: 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-row {
  display: flex;
  gap: 24rpx;
}

.item-half {
  flex: 1;
}

.label {
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 12rpx;
}

.input-box {
  background-color: #f8fafc; /* Very light cool grey */
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 600;
}

.text-green {
  color: #10b981;
}

.textarea-box {
  width: 100%;
  background-color: #f8fafc;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #475569;
  height: 200rpx;
  box-sizing: border-box;
}

/* Image Grid */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.grid-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 20rpx;
  background-color: #f1f5f9;
}

.add-img-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 20rpx;
  border: 4rpx dashed #cbd5e1; /* Dashed border */
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #fff;
}

.plus-icon {
  font-size: 64rpx;
  color: #cbd5e1;
  font-weight: 300;
}

/* Footer */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  background-color: #fff;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.save-btn {
  background-color: #059669; /* Green-600 */
  color: #fff;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: bold;
  padding: 24rpx 0;
  width: 100%;
}
