/* pages/farmer/reviews/reviews.wxss */
.container {
  min-height: 100vh;
  background-color: #f8fafc;
  padding: 32rpx; 
}

/* Tabs */
.tabs {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.tab-item {
  padding: 12rpx 32rpx;
  background-color: #fff;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #64748b;
  font-weight: 500;
}

.tab-item.active {
  background-color: #059669; /* Green active tab */
  color: #fff;
}

/* Review Card */
.review-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(148, 163, 184, 0.05);
}

.card-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background-color: #f1f5f9;
}

.user-info {
  flex: 1;
}

.username {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
  margin-bottom: 4rpx;
}

.rating {
  display: flex;
  gap: 4rpx;
}

.rating-star {
  font-size: 24rpx;
}

.date {
  font-size: 24rpx;
  color: #cbd5e1;
}

.review-content {
  font-size: 28rpx;
  color: #334155;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.review-images {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.review-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background-color: #f1f5f9;
}

.product-tag {
  display: inline-block;
  background-color: #f8fafc;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 24rpx;
}

/* Reply Section */
.reply-section {
  border-top: 1rpx solid #f1f5f9; /* Optional divider */
  padding-top: 24rpx;
}

.reply-box {
  background-color: #ecfdf5; /* Light green bg for reply */
  border-radius: 16rpx;
  padding: 24rpx;
}

.reply-box.replied {
  background-color: #ecfdf5; 
}

.reply-box.input-mode {
  background-color: #f8fafc;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx; /* Tighter padding for input bar */
  padding-left: 24rpx;
}

.reply-tag {
  display: inline-block;
  background-color: #d1fae5;
  color: #059669;
  font-size: 22rpx;
  font-weight: 700;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.reply-text {
  font-size: 28rpx;
  color: #047857;
  line-height: 1.5;
}

.reply-input {
  flex: 1;
  font-size: 28rpx;
  color: #334155;
}

.reply-btn {
  font-size: 26rpx;
  color: #fff;
  background-color: #059669;
  border-radius: 12rpx;
  padding: 12rpx 10rpx;
  line-height: 1.5;
  margin: 0;
  width: auto;
  min-width: 80rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
