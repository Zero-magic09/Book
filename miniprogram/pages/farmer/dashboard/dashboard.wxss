/** pages/farmer/dashboard/dashboard.wxss **/
.container {
  min-height: 100vh;
  background-color: #f7f9fc; /* Light background */
  padding-bottom: 200rpx; /* Space for TabBar */
}

.content {
  padding: 30rpx;
}

/* 1. Profile Card */
.profile-card {
  background-color: #fff;
  border-radius: 40rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
  margin-bottom: 30rpx;
}

.profile-info {
  display: flex;
  align-items: center;
}

.avatar-wrapper {
  position: relative;
  margin-right: 24rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
  background-color: #eee;
}

.verified-icon {
  position: absolute;
  bottom: -6rpx;
  right: -6rpx;
  width: 32rpx;
  height: 32rpx;
  background-color: #10b981; /* Green */
  color: #fff;
  border-radius: 50%;
  border: 4rpx solid #fff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.info-text {
  display: flex;
  flex-direction: column;
}

.farm-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.farm-location {
  font-size: 24rpx;
  color: #10b981;
}

.settings-btn {
  width: 80rpx;
  height: 80rpx;
  background-color: #f0fdf4; /* Light Green */
  border-radius: 20rpx; /* Changed to round rect per image? Image looks circle inside rect maybe, keeping logical */
  border-radius: 50%; /* Image shows circle */
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-gear {
  color: #059669;
  font-size: 40rpx;
}

/* 2. Stats Row */
.stats-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.stat-card {
  flex: 1;
  background-color: #fff;
  border-radius: 30rpx;
  padding: 30rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stat-prefix {
  font-size: 24rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #6b7280;
}

/* 3. Action Buttons */
.action-row {
  display: flex;
  gap: 30rpx;
  margin-bottom: 40rpx;
}

.action-btn {
  flex: 1;
  height: 200rpx; /* Taller cards */
  border-radius: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.05);
}

.action-primary {
  background-color: #10b981; /* Green */
}

.action-secondary {
  background-color: #fff;
  border: 1px solid #e5e7eb;
}

.action-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.box-glass {
  background-color: rgba(255, 255, 255, 0.2);
}

.box-green {
  background-color: #f0fdf4;
}

.action-icon {
  font-size: 48rpx;
  font-weight: 300;
}

.icon-plus {
  font-size: 56rpx;
  font-weight: 400;
}

.icon-edit {
  color: #10b981;
  font-size: 40rpx;
}

.action-text {
  font-size: 28rpx;
  font-weight: bold;
}

.text-white { color: #fff; }
.text-green { color: #047857; }


/* 4. Orders Section */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1f2937;
}

.view-all {
  font-size: 24rpx;
  color: #10b981;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-card {
  background-color: #fff;
  border-radius: 30rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.02);
}

.order-img {
  width: 90rpx;
  height: 90rpx;
  border-radius: 20rpx;
  background-color: #f3f4f6;
  margin-right: 24rpx;
}

.order-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.product-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.buyer-info {
  font-size: 24rpx;
  color: #9ca3af;
}

.order-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.product-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #10b981;
  margin-bottom: 8rpx;
}

.order-time {
  font-size: 22rpx;
  color: #d1d5db; /* Light grey */
  background-color: #f3f4f6;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

/* Empty State */
.empty-state {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  box-sizing: border-box;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #6b7280;
}

.empty-hint {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 10rpx;
}

