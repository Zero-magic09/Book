<view class="container">
  
  <!-- Header Section -->
  <view class="profile-header">
    <view class="user-card" bindtap="handleEditProfile">
      <image class="avatar" src="{{farmerInfo.avatar}}" mode="aspectFill" />
      <view class="user-info">
        <text class="nickname">{{farmerInfo.name}}</text>
        <view class="user-tag">普通农户</view>
      </view>

    </view>
  </view>

  <!-- Stats Row -->
  <view class="stats-row">
    <view class="stat-item" wx:for="{{stats}}" wx:key="id">
      <text class="stat-num">{{item.val}}</text>
      <text class="stat-label">{{item.label}}</text>
    </view>
  </view>

  <!-- Farm Management Section -->
  <view class="section-card">
    <view class="section-header">
      <text class="section-title">农场管理</text>
    </view>
    <view class="service-list">
      <view class="service-item" wx:for="{{menuItems}}" wx:key="label" bindtap="handleMenuClick" data-url="{{item.url}}">
        <view class="service-left">
          <text class="service-icon">{{item.icon}}</text>
          <text class="service-name">{{item.label}}</text>
        </view>
        <view class="service-right">
          <text class="service-desc {{item.statusColor}}">{{item.status}}</text>
          <text class="service-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Logout Button -->
  <view class="logout-section">
    <view class="logout-btn" bindtap="handleLogout">
      退出登录
    </view>
  </view>
  
  <!-- Footer Version -->
  <view class="footer-version">
    VILLAGE DIRECT FARMER · V1.0.2 STABLE
  </view>

  <ui-tabbar activeTab="{{activeTab}}" items="{{tabItems}}" bind:select="handleTabSelect" />
</view>
