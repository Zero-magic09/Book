/** pages/farmer/orders/orders.wxss **/
.container {
  min-height: 100vh;
  background-color: #f7f9fc;
  padding: 32rpx;
  padding-bottom: 200rpx;
}

/* Header */
.top-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 32rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 900;
  color: #1e293b;
}

.filter-pills {
  display: flex;
  background-color: #fff;
  padding: 4rpx;
  border-radius: 999rpx;
  border: 2rpx solid #e2e8f0;
}

.pill {
  padding: 12rpx 32rpx;
  font-size: 24rpx;
  color: #94a3b8;
  border-radius: 999rpx;
  font-weight: 700;
  transition: all 0.2s;
}

.pill-active {
  background-color: #10b981;
  color: #fff;
}

/* Order List */
.order-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.order-card {
  background-color: #fff;
  border-radius: 40rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
  border: 2rpx solid rgba(229, 231, 235, 0.4);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f8fafc;
}

.order-id {
  font-size: 24rpx;
  font-weight: 700;
  color: #cbd5e1; /* very light grey */
  letter-spacing: 1px;
}

.status-tag {
  font-size: 24rpx;
  font-weight: 900;
}

.status-pending { color: #f59e0b; } /* Orange */
.status-shipped { color: #10b981; } /* Green */
.status-unpaid { color: #10b981; } /* Design shows green for text here too usually, or could be slate */

.product-item {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.product-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  background-color: #f1f5f9;
}

.info-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.prod-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.prod-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #1e293b;
  flex: 1;
  margin-right: 16rpx;
}

.prod-price {
  font-size: 26rpx;
  font-weight: 700;
  color: #64748b;
}

.prod-specs {
  font-size: 22rpx;
  color: #94a3b8;
}

.order-footer-info {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #f8fafc;
}

.total-summary {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.summary-label {
  font-size: 24rpx;
  color: #94a3b8;
}

.summary-val {
  font-size: 32rpx;
  font-weight: 900;
  color: #10b981;
}

.prod-loc {
  font-size: 22rpx;
  color: #94a3b8;
  display: flex;
  align-items: flex-start;
}

.icon-loc {
  margin-right: 4rpx;
  font-size: 20rpx;
  margin-top: 2rpx;
}

.loc-text {
  flex: 1;
  line-height: 1.4;
}

/* Action Footer */
.action-footer {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
  padding-top: 8rpx;
}

.btn {
  flex: 1;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
}

.btn-outline {
  border: 2rpx solid #e2e8f0;
  color: #64748b;
  background-color: #fff;
}

.btn-filled {
  background-color: #10b981; /* Green */
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.2);
}

/* Empty State */
.empty-state {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  box-sizing: border-box;
  text-align: center;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #6b7280;
}

