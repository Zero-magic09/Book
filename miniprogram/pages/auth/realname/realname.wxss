/** pages/auth/realname/realname.wxss **/
.container {
  min-height: 100vh;
  background-color: #f8fafc;
  padding: 32rpx;
}

/* Status Card */
.status-card {
  background-color: #fff;
  border-radius: 32rpx;
  padding: 64rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(148, 163, 184, 0.05);
}

.icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.icon-wrapper.success {
  background-color: #d1fae5;
}

.status-icon {
  font-size: 64rpx;
  color: #10b981;
  font-weight: 700;
}

.status-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 16rpx;
}

.status-desc {
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 64rpx;
}

.info-row {
  width: 100%;
  display: flex;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row .label {
  color: #64748b;
  font-size: 28rpx;
}

.info-row .value {
  color: #1e293b;
  font-weight: 600;
  font-size: 28rpx;
}

/* Form Card */
.form-card {
  background-color: #fff;
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(148, 163, 184, 0.05);
}

.form-header {
  margin-bottom: 48rpx;
}

.form-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1e293b;
  display: block;
  margin-bottom: 12rpx;
}

.form-desc {
  font-size: 26rpx;
  color: #94a3b8;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-group .label {
  display: block;
  font-size: 28rpx;
  color: #334155;
  margin-bottom: 16rpx;
  font-weight: 600;
}

.input {
  width: 100%;
  height: 96rpx;
  background-color: #f8fafc;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #1e293b;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.input:focus {
  border-color: #10b981;
  background-color: #fff;
}

.submit-btn {
  margin-top: 64rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.25);
}
