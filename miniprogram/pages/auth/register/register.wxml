<view class="container px-6 py-8 animate-fade-in">

  <!-- Header -->
  <view class="header mb-10 text-center">
    <view class="logo-box">
      <!-- SVG Placeholder -->
      <view class="logo-icon"></view>
    </view>
    <view class="title">{{title}}</view>
    <view class="desc">欢迎加入乡味直达</view>
  </view>

  <!-- Register Form -->
  <view class="form-card space-y-5">
    <!-- Account Input -->
    <view class="space-y-1">
      <text class="label">账号 / 手机号</text>
      <ui-input 
        placeholder="请输入您的手机号" 
        data-field="account"
        bindinput="handleInput"
      />
    </view>

    <!-- Password Input -->
    <view class="space-y-1">
      <text class="label">安全密码</text>
      <ui-input 
        type="password" 
        password="{{true}}"
        placeholder="请输入您的密码" 
        data-field="password"
        bindinput="handleInput"
      />
    </view>

    <!-- Register Button -->
    <view class="mt-2">
      <ui-button bindclick="handleSubmit" disabled="{{loading}}" className="shadow-lg">
        {{loading ? '注册中...' : '立即注册'}}
      </ui-button>
    </view>
  </view>

  <!-- Login Link -->
  <block wx:if="{{role !== 'ADMIN'}}">
    <view class="text-center text-sm" style="margin-top: 58rpx;">
      <text class="text-slate-400 font-light">已有账号？</text>
      <text class="text-emerald-600 font-bold ml-2 underline" bindtap="handleLogin">立即登录</text>
    </view>
  </block>
</view>
