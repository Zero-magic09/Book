<view class="container">
  <!-- Header Section -->
  <view class="profile-header">
    <view class="user-card" bindtap="handleEditProfile">
      <image class="avatar" src="{{userInfo.avatar}}" mode="aspectFill" />
      <view class="user-info">
        <text class="nickname">{{userInfo.nickname}}</text>
        <view class="user-tag">{{userInfo.tag}}</view>
      </view>

    </view>
  </view>

  <!-- Stats Row -->
  <view class="stats-row">
    <view class="stat-item">
      <text class="stat-num">{{stats.footprint}}</text>
      <text class="stat-label">我的足迹</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.favorites}}</text>
      <text class="stat-label">收藏产品</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.points}}</text>
      <text class="stat-label">生态积分</text>
    </view>
  </view>

  <!-- Orders Section -->
  <view class="section-card">
    <view class="section-header">
      <text class="section-title">我的溯源单</text>
      <view class="section-link" bindtap="navigateTo" data-url="/pages/user/orders/orders">
        全部订单 <text class="link-arrow">›</text>
      </view>
    </view>
    <view class="order-icons">
      <view class="order-icon-item" bindtap="navigateToOrders" data-type="payment">
        <text class="icon">💳</text>
        <text class="label">待支付</text>
        <view class="badge" wx:if="{{orderStats.payment > 0}}">{{orderStats.payment}}</view>
      </view>
      <view class="order-icon-item" bindtap="navigateToOrders" data-type="shipment">
        <text class="icon">📦</text>
        <text class="label">待发货</text>
        <view class="badge" wx:if="{{orderStats.shipment > 0}}">{{orderStats.shipment}}</view>
      </view>
      <view class="order-icon-item" bindtap="navigateToOrders" data-type="receipt">
        <text class="icon">🚚</text>
        <text class="label">待收货</text>
        <view class="badge" wx:if="{{orderStats.receipt > 0}}">{{orderStats.receipt}}</view>
      </view>
      <view class="order-icon-item" bindtap="navigateToOrders" data-type="review">
        <text class="icon">📝</text>
        <text class="label">待评价</text>
        <view class="badge" wx:if="{{orderStats.review > 0}}">{{orderStats.review}}</view>
      </view>
    </view>
  </view>

  <!-- Services Section -->
  <view class="section-card">
    <view class="section-header">
      <text class="section-title">常用服务</text>
    </view>
    <view class="service-list">
      <view class="service-item" wx:for="{{services}}" wx:key="id" bindtap="navigateTo" data-url="{{item.url}}">
        <view class="service-left">
          <text class="service-icon">{{item.icon}}</text>
          <text class="service-name">{{item.name}}</text>
        </view>
        <view class="service-right">
          <text class="service-desc" style="{{item.descColor ? 'color:' + item.descColor : ''}}">{{item.desc}}</text>
          <text class="service-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Logout Button -->
  <view class="logout-section">
    <view class="logout-btn" bindtap="handleLogout">
       退出登录
    </view>
  </view>

  <ui-tabbar activeTab="{{activeTab}}" items="{{tabItems}}" bind:select="handleTabSelect" />
</view>
