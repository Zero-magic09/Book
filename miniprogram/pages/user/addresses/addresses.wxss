/** pages/user/addresses/addresses.wxss **/
.container {
  min-height: 100vh;
  background-color: #f8fafc;
  padding: 24rpx 32rpx 160rpx;
}

.address-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.address-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(148, 163, 184, 0.05);
}

.card-left {
  flex: 1;
}

.user-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  gap: 16rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
}

.user-phone {
  font-size: 28rpx;
  color: #64748b;
}

.default-tag {
  background-color: #10b981;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.custom-tag {
  background-color: #f1f5f9;
  color: #10b981;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.address-detail {
  font-size: 28rpx;
  color: #334155;
  line-height: 1.5;
}

.card-right {
  padding-left: 16rpx;
  margin-left: 16rpx;
  border-left: 1rpx solid #f1f5f9;
  display: flex;
  align-items: center;
  gap: 16rpx;
  height: 60rpx;
}

.action-btn {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s;
}

.edit-btn {
  color: #64748b;
  background-color: #f1f5f9;
}

.delete-btn {
  color: #ef4444;
  background-color: #fee2e2;
}

.icon {
  font-size: 24rpx;
}

.footer-btn {
  position: fixed;
  bottom: 40rpx;
  left: 32rpx;
  right: 32rpx;
  z-index: 10;
}

.add-btn {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #fff;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.25);
}

.plus-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
  font-weight: 300;
}
