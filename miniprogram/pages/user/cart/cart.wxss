/** pages/user/cart/cart.wxss **/
.container {
  min-height: 100vh;
  background-color: #f8fafc;
  background-color: #f8fafc;
  padding-bottom: 240rpx; /* Space for footer + tabbar */
}

/* Page Header */
.page-header {
  padding: 40rpx 40rpx 20rpx;
  background-color: transparent;
}

.page-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #1e293b;
  letter-spacing: -1rpx;
}

/* Cart Section */
.cart-section {
  padding: 0 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 24rpx 8rpx;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.section-count {
  font-size: 26rpx;
  color: #94a3b8;
}

/* Cart List & Items */
.cart-item {
  background-color: #fff;
  border-radius: 40rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(148, 163, 184, 0.05);
}

.item-image-wrapper {
  position: relative;
}

.item-image, .item-image-placeholder {
  width: 180rpx;
  height: 180rpx;
  border-radius: 32rpx;
  background-color: #f1f5f9;
}

.item-image-placeholder::before {
  content: '🌿';
  font-size: 64rpx;
  opacity: 0.3;
}

.item-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 180rpx;
  padding: 4rpx 0;
}

.item-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #334155;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.item-farmer {
  font-size: 24rpx;
  color: #94a3b8;
}

.item-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-top: auto;
}

.item-price {
  font-size: 36rpx;
  font-weight: 800;
  color: #10b981;
}

.price-unit {
  font-size: 24rpx;
  color: #cbd5e1;
  font-weight: 400;
  margin-left: 4rpx;
}

/* Quantity Pill */
.quantity-control {
  display: flex;
  align-items: center;
  background-color: #f8fafc;
  border-radius: 32rpx;
  padding: 4rpx 6rpx;
  height: 56rpx;
}

.qty-btn {
  width: 56rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #64748b;
  font-size: 32rpx;
  font-weight: 300;
  line-height: 1;
}

.qty-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  min-width: 40rpx;
  text-align: center;
}

/* Floating Footer */
.floating-footer {
  position: fixed;
  bottom: calc(env(safe-area-inset-bottom) + 80px); /* Custom TabBar Height (64) + spacing */
  left: 32rpx;
  right: 32rpx;
  background-color: #fff;
  border-radius: 40rpx; /* Capsule shape */
  padding: 20rpx 24rpx 20rpx 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 12rpx 32rpx -4rpx rgba(16, 185, 129, 0.15);
  z-index: 100;
}

.total-section {
  display: flex;
  flex-direction: column;
}

.total-label {
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.total-price {
  font-size: 40rpx;
  font-weight: 800;
  color: #10b981;
  line-height: 1;
}

.checkout-btn {
  background-color: #10b981;
  color: #fff;
  padding: 20rpx 48rpx;
  border-radius: 32rpx;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
}

/* Empty State */
.empty-cart {
  text-align: center;
  padding: 200rpx 0;
}
.empty-text { font-size: 32rpx; color: #cbd5e1; margin-bottom: 16rpx; }
.empty-hint { font-size: 26rpx; color: #94a3b8; }
