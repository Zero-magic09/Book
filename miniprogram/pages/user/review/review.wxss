.container {
  padding: 20rpx;
  background-color: #f7f8fa;
  min-height: 100vh;
}

.review-card {
  background: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.product-info {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  border-bottom: 1rpx solid #eee;
  padding-bottom: 20rpx;
}

.prod-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.prod-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.rating-section {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-right: 20rpx;
}

.stars {
  display: flex;
}

.star {
  font-size: 50rpx;
  color: #ddd;
  margin-right: 10rpx;
  transition: color 0.2s;
}

.star.active {
  color: #ffc107;
}

.rating-text {
  margin-left: 20rpx;
  font-size: 28rpx;
  color: #999;
}

.review-input {
  width: 100%;
  height: 200rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.btn-area {
  margin-top: 40rpx;
}

.submit-btn {
  background: #07c160;
  color: white;
  font-weight: 500;
  border-radius: 44rpx;
}
