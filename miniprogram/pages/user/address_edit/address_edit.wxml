<view class="container">
    <view class="form-group">
        <view class="form-item">
            <text class="label">收货人</text>
            <input class="input" placeholder="请填写收货人姓名" value="{{form.name}}" bindinput="handleInput" data-field="name" />
        </view>
        <view class="form-item">
            <text class="label">手机号码</text>
            <input class="input" type="number" placeholder="请填写收货人手机号" value="{{form.phone}}" bindinput="handleInput" data-field="phone" />
        </view>
        <view class="form-item">
            <text class="label">所在地区</text>
            <picker mode="region" bindchange="handleRegionChange" value="{{region}}">
                <view class="picker">
                    {{region[0]}} {{region[1]}} {{region[2]}}
                </view>
            </picker>
        </view>
        <view class="form-item">
            <text class="label">详细地址</text>
            <textarea class="textarea" placeholder="街道、楼牌号等" value="{{form.detail}}" bindinput="handleInput" data-field="detail"></textarea>
        </view>
    </view>

    <view class="form-group">
        <view class="form-item switch-item">
            <text class="label">设为默认收货地址</text>
            <switch checked="{{form.isDefault}}" bindchange="handleSwitchChange" color="#f59e0b" />
        </view>
    </view>

    <view class="footer-btn">
        <button class="save-btn" bindtap="handleSave">保存地址</button>
    </view>
</view>
