<view class="container">
  <view class="header">
    <text class="title">今日好券</text>
    <text class="subtitle">先领券，再下单</text>
  </view>

  <view class="coupon-list">
    <view class="coupon-item" wx:for="{{coupons}}" wx:key="id">
      <view class="left">
        <view class="value">
          <text class="symbol">¥</text>
          <text class="num">{{item.value}}</text>
        </view>
        <view class="condition">{{item.condition}}</view>
      </view>
      <view class="middle">
        <view class="name">{{item.name}}</view>
        <view class="expiry">{{item.expiry}} 前有效</view>
        <view class="progress-bar">
          <view class="progress" style="width: {{100 - (item.remaining * 10)}}%;"></view> <!-- Fake progress or calculated -->
        </view>
        <view class="tips">剩 {{item.remaining}} 张</view>
      </view>
      <view class="right">
        <view class="claim-btn {{item.claimed ? 'disabled' : ''}}" bindtap="{{item.claimed ? '' : 'handleClaim'}}" data-id="{{item.id}}">
          {{item.claimed ? '已领取' : '立即领'}}
        </view>
      </view>
    </view>
    
    <view class="empty" wx:if="{{coupons.length === 0}}">
      <text>暂无优惠券可领~</text>
    </view>
  </view>
</view>
