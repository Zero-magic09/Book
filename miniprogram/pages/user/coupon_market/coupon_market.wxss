.container {
  min-height: 100vh;
  background-color: #f53f3f;
  padding: 30rpx;
}

.header {
  color: #fff;
  margin-bottom: 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
}

.subtitle {
  font-size: 26rpx;
  opacity: 0.8;
}

.coupon-item {
  background: #fff;
  border-radius: 12rpx;
  display: flex;
  height: 180rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.left {
  width: 180rpx;
  background: linear-gradient(135deg, #fff1f0, #ffe4e6);
  color: #e11d48;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-right: 2rpx dashed #fcd7d7;
}

.value {
  display: flex;
  align-items: baseline;
}

.symbol {
  font-size: 28rpx;
}

.num {
  font-size: 60rpx;
  font-weight: bold;
}

.condition {
  font-size: 22rpx;
  margin-top: 8rpx;
}

.middle {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.expiry {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.progress-bar {
  height: 6rpx;
  background: #f1f5f9;
  border-radius: 6rpx;
  width: 100%;
  margin-bottom: 8rpx;
  overflow: hidden;
}

.progress {
  height: 100%;
  background: #e11d48;
}

.tips {
  font-size: 20rpx;
  color: #999;
}

.right {
  width: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-right: 20rpx;
}

.claim-btn {
  background: #e11d48;
  color: #fff;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
}

.claim-btn.disabled {
  background: #e2e8f0;
  color: #94a3b8;
}

.empty {
  text-align: center;
  color: rgba(255,255,255,0.8);
  margin-top: 100rpx;
}
