.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
  padding: 40rpx 30rpx;
  padding-bottom: 200rpx; /* 为固定底栏留出空间 */
}

/* 金额卡片优化 */
.amount-card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  margin-bottom: 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(148, 163, 184, 0.1);
  position: relative;
  overflow: hidden;
}

.amount-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 8rpx;
  background: linear-gradient(90deg, #10b981, #34d399);
}

.amount-card .label {
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 24rpx;
  display: block;
  letter-spacing: 2rpx;
}

.amount {
  color: #0f172a;
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 16rpx;
}

.amount .symbol {
  font-size: 44rpx;
  font-weight: 600;
  margin-right: 8rpx;
}

.amount .value {
  font-size: 80rpx;
  font-weight: 700;
  font-family: 'DIN Alternate', -apple-system, BlinkMacSystemFont, sans-serif;
}

.order-no {
  font-size: 24rpx;
  color: #94a3b8;
  background: #f8fafc;
  padding: 8rpx 24rpx;
  border-radius: 100rpx;
  display: inline-block;
}

.order-info {
  font-size: 26rpx;
  color: #10b981;
  font-weight: 500;
}

/* 多订单列表样式 */
.orders-list {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(148, 163, 184, 0.05);
}

.order-item {
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f1f5f9;
}

.order-item:last-child {
  border-bottom: none;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-no-small {
  font-size: 24rpx;
  color: #64748b;
}

.order-amount {
  font-size: 28rpx;
  color: #0f172a;
  font-weight: 600;
}

/* 支付方式列表优化 */
.payment-section {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(148, 163, 184, 0.05);
}

.section-title {
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 600;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: #10b981;
  margin-right: 16rpx;
  border-radius: 4rpx;
}

.method-item {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 2rpx solid #f1f5f9;
  transition: all 0.2s ease;
}

.method-item:last-child {
  border-bottom: none;
}

.method-item.selected {
  background: rgba(16, 185, 129, 0.02);
}

.method-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 28rpx;
  background: #f8fafc;
  border-radius: 16rpx;
}

.method-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  color: #334155;
}

.radio {
  width: 44rpx;
  height: 44rpx;
  border: 4rpx solid #e2e8f0;
  border-radius: 50%;
  position: relative;
  box-sizing: border-box;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.radio.checked {
  border-color: #10b981;
  background: #10b981;
}

.radio.checked::after {
  content: '';
  width: 14rpx;
  height: 14rpx;
  background: #fff;
  border-radius: 50%;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

/* 底部按钮优化 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx 40rpx 60rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px);
  box-shadow: 0 -10rpx 40rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.pay-btn {
  background: linear-gradient(90deg, #10b981, #059669);
  color: #ffffff;
  border-radius: 100rpx;
  font-weight: 600;
  font-size: 32rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 12rpx 30rpx rgba(16, 185, 129, 0.3);
  transition: all 0.2s ease;
}

.pay-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 10rpx rgba(16, 185, 129, 0.2);
  opacity: 0.9;
}

.pay-tip {
  text-align: center;
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pay-tip::before {
  content: '🛡️';
  font-size: 24rpx;
  margin-right: 8rpx;
}

/* 收货地址区块 */
.address-section {
  background: #fff;
  border-radius: 24rpx;
  margin: 32rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.title-icon {
  margin-right: 8rpx;
}

.selected-address {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  position: relative;
}

.no-address {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  position: relative;
}

.address-content {
  flex: 1;
  padding-right: 30rpx;
}

.address-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.address-row:last-child {
  margin-bottom: 0;
}

.address-row-full {
  align-items: flex-start;
}

.label-tag {
  font-size: 22rpx;
  color: #fff;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.address-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

.address-phone {
  font-size: 28rpx;
  color: #334155;
  font-weight: 500;
}

.address-detail {
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.5;
  flex: 1;
}

.address-arrow {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  font-size: 40rpx;
  color: #94a3b8;
}

.no-address-text {
  flex: 1;
  font-size: 28rpx;
  color: #94a3b8;
}

/* 地址选择弹窗 */
.address-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.address-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 101;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.modal-close {
  font-size: 40rpx;
  color: #94a3b8;
  padding: 8rpx;
}

.modal-body {
  flex: 1;
  padding: 24rpx;
  max-height: 55vh;
  overflow-x: hidden;
  overflow-y: auto;
  box-sizing: border-box;
  width: 100%;
}

/* 地址卡片 */
.address-card {
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  position: relative;
  border: 2rpx solid transparent;
  box-sizing: border-box;
  overflow: hidden;
}

.address-card.selected {
  border-color: #10b981;
  background: #f0fdf4;
}

.address-card-main {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
  padding-right: 40rpx;
}

.card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  margin-right: 12rpx;
}

.card-phone {
  font-size: 26rpx;
  color: #64748b;
}

.default-tag {
  font-size: 20rpx;
  color: #fff;
  background: #10b981;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-left: 12rpx;
}

.card-detail {
  font-size: 26rpx;
  color: #64748b;
  word-break: break-all;
  padding-right: 40rpx;
  line-height: 1.5;
}

.card-check {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  color: #10b981;
  font-weight: bold;
}

/* 无保存地址 */
.no-saved-address {
  text-align: center;
  padding: 48rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #94a3b8;
}

/* 手动填写地址 */
.manual-input-section {
  margin-top: 24rpx;
  border-top: 1rpx solid #f1f5f9;
  padding-top: 20rpx;
  box-sizing: border-box;
  width: 100%;
}

.manual-toggle {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #3b82f6;
}

.toggle-icon {
  font-size: 20rpx;
  margin-right: 12rpx;
}

.manual-form {
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-top: 16rpx;
  box-sizing: border-box;
  width: 100%;
}

.form-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  box-sizing: border-box;
  width: 100%;
}

.form-item:last-of-type {
  margin-bottom: 0;
}

.form-label {
  width: 140rpx;
  font-size: 26rpx;
  color: #64748b;
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.form-input {
  flex: 1;
  min-width: 0;
  background: #fff;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-picker {
  flex: 1;
  min-width: 0;
}

.picker-text {
  background: #fff;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  color: #64748b;
  width: 100%;
}

.use-manual-btn {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  font-size: 28rpx;
  padding: 20rpx;
  margin-top: 12rpx;
}
