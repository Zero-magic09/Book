/** pages/user/traceability/traceability.wxss **/
.container {
  min-height: 100vh;
  background-color: #f8fafc;
  padding-bottom: 140rpx;
}

.header {
  padding: 32rpx;
  background-color: #fff;
  margin-bottom: 16rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 900;
  color: #0f172a;
}

/* Page Layout */
.trace-list {
  padding: 0 32rpx;
}

/* Trace Card */
.trace-card {
  background-color: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(148, 163, 184, 0.05);
}

/* Card Header */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 0;
  border-bottom: none;
}

.order-id {
  font-size: 26rpx;
  color: #94a3b8;
}

.order-status {
  font-size: 28rpx;
  font-weight: 600;
  color: #059669; /* Green status */
}

/* Card Content */
.card-content {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 20rpx;
  background-color: #f1f5f9;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 8rpx;
}

.order-time {
  font-size: 22rpx;
  color: #cbd5e1;
  margin-bottom: auto;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.product-price {
  font-size: 34rpx;
  font-weight: 800;
  color: #1e293b;
}

.product-quantity {
  font-size: 24rpx;
  color: #94a3b8;
}

/* Card Actions / Footer */
.card-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}

.btn {
  height: 64rpx;
  padding: 0 32rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
}

.btn-secondary {
  background-color: #f1f5f9;
  color: #64748b;
}

.btn-primary {
  background-color: #10b981; /* Green */
  color: #fff;
  flex: 1; /* Make it wider if desired, or auto */
  max-width: 320rpx; /* Limit width */
}

.icon-shield {
  margin-right: 8rpx;
  font-size: 24rpx;
}

/* Empty State */
.empty-trace { text-align: center; padding: 160rpx 0; }
.empty-text { font-size: 32rpx; color: #cbd5e1; margin-bottom: 16rpx; }
.empty-hint { font-size: 26rpx; color: #94a3b8; }

/* Modal Styles */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  justify-content: center;
  align-items: center;
  backdrop-filter: blur(4px);
}

.modal-content {
  width: 85%;
  height: 60vh; /* Fixed height as requested */
  background: #fff;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  animation: slideUp 0.3s ease-out;
  box-sizing: border-box; /* Ensure padding doesn't expand width */
}

@keyframes slideUp {
  from { transform: translateY(50px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.modal-header {
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
  box-sizing: border-box;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.close-btn {
  font-size: 44rpx;
  color: #999;
  line-height: 1;
  padding: 10rpx;
}

.modal-body {
  padding: 30rpx;
  overflow-y: auto;
  box-sizing: border-box; /* Critical for correct width */
  width: 100%;
  flex: 1; /* Allow scrolling within fixed height */
}

/* Trace Info Header */
.trace-info-header {
  background: #f9fbf9;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 40rpx;
  border: 1rpx solid #e8f5e9;
  box-sizing: border-box;
}

.info-row {
  display: flex;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-row .label {
  color: #666;
  width: 160rpx;
}

.info-row .value {
  color: #333;
  font-weight: 500;
  flex: 1;
}

.info-row .value.highlight {
  color: #07c160;
  font-family: monospace;
}

/* Timeline Styles (Copied & Adapted from product_detail) */
.timeline-container {
  padding-left: 10rpx;
}

.timeline-item {
  display: flex;
  margin-bottom: 40rpx;
  width: 100%; /* Ensure it fits parent */
  box-sizing: border-box;
}

.timeline-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 24rpx;
  flex-shrink: 0; /* Prevent dots from shrinking */
}

.timeline-dot {
  width: 20rpx;
  height: 20rpx;
  background: #07c160;
  border-radius: 50%;
  border: 4rpx solid #e8f5e9;
}

.timeline-line {
  width: 2rpx;
  flex: 1;
  background: #e0e0e0;
  margin-top: 8rpx;
}

.timeline-content {
  flex: 1;
  min-width: 0; /* Fix flex overflow */
}

.log-card {
  background: #fff;
  border-radius: 12rpx;
  box-sizing: border-box; /* Safe padding */
  /* box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03); */
}

.log-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.log-type {
  font-size: 28rpx;
  font-weight: bold;
  color: #07c160;
  background: #e8f5e9;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.log-date {
  font-size: 24rpx;
  color: #999;
}

.log-desc {
  font-size: 28rpx;
  color: #555;
  line-height: 1.5;
}

.security-footer {
  margin-top: 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #07c160;
  font-size: 24rpx;
  background: #f0fdf4;
  padding: 16rpx;
  border-radius: 100rpx;
}

.security-footer .icon-shield {
  margin-right: 10rpx;
}
