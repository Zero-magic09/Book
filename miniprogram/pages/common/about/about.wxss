/** pages/common/about/about.wxss **/
.container {
  min-height: 100vh;
  background-color: #f8fafc;
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
  display: none; /* Hide if no source */
}

.logo-placeholder {
  width: 160rpx;
  height: 160rpx;
  background-color: #10b981;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  color: #fff;
  font-weight: 800;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.3);
}

.app-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 12rpx;
}

.version {
  font-size: 28rpx;
  color: #94a3b8;
}

.content-section {
  flex: 1;
}

.cell-group {
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(148, 163, 184, 0.05);
}

.cell {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.cell:last-child {
  border-bottom: none;
}

.label {
  font-size: 30rpx;
  color: #334155;
}

.value {
  font-size: 30rpx;
  color: #64748b;
}

.arrow {
  color: #cbd5e1;
  font-size: 32rpx;
}

.footer {
  text-align: center;
}

.copyright {
  font-size: 20rpx;
  color: #cbd5e1;
}
