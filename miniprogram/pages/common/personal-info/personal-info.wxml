<view class="container">
  <view class="avatar-section" bindtap="handleAvatarChoose">
    <image class="avatar" src="{{userInfo.avatar}}" mode="aspectFill" />
    <view class="edit-hint">点击更换头像</view>
  </view>

  <view class="form-card">
    <view class="form-item">
      <view class="label">昵称 / 姓名</view>
      <input class="input-text" value="{{userInfo.name}}" bindinput="handleInput" data-field="name" placeholder="请输入姓名" />
    </view>
    <view class="divider"></view>
    
    <view class="form-item">
      <view class="label">手机号</view>
      <view class="read-only-text">{{userInfo.phone}}</view>
    </view>
    <view class="divider"></view>

    <view class="form-item">
      <view class="label">当前称号</view>
      <view class="read-only-text tag">{{userInfo.roleTag}}</view>
    </view>
  </view>

  <view class="btn-area">
    <ui-button type="primary" size="large" bindtap="handleSave">保存修改</ui-button>
  </view>
</view>
