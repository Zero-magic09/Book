/* components/ui-badge/ui-badge.wxss */
@import "../../app.wxss";

.badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 9999rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.badge-default {
  background-color: var(--gray-100);
  color: var(--slate-700);
}

.badge-success {
  background-color: var(--emerald-100);
  color: var(--emerald-700);
}

.badge-warning {
  background-color: var(--amber-100);
  color: var(--amber-600);
}

.badge-error {
  background-color: #fee2e2;
  color: var(--red-600);
}
